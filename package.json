{
  "name": "agenticz-demo-voice",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Agenticz Demo Voice — private back-office dashboard for triggering live AI voice demo calls via Retell.",
  "scripts": {
    "dev": "vercel dev",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:migrate": "node --env-file=.env scripts/migrate.js",
    "db:seed": "node --env-file=.env scripts/seed-user.js",
    "retell:setup": "node --env-file=.env scripts/setup-retell-agent.js",
    "retell:setup-receptionist": "node --env-file=.env scripts/setup-retell-receptionist.js",
    "retell:setup-website-voice": "node --env-file=.env scripts/setup-retell-website-voice.js"
  },
  "devDependencies": {
    "vercel": "^39.0.0",
    "vitest": "^2.1.0"
  },
  "dependencies": {
    "@libsql/client": "^0.17.2",
    "bcryptjs": "^3.0.3",
    "cookie": "^1.1.1",
    "jose": "^6.2.2"
  }
}
