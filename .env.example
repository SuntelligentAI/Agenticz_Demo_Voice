# Agenticz Demo Voice — environment variables
# Real values are added in later phases

# Turso database
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Auth
AUTH_JWT_SECRET=
AUTH_COOKIE_NAME=agenticz_session
AUTH_SESSION_TTL_SECONDS=28800

# Initial admin user (used by seed-user.js only)
ADMIN_EMAIL=
ADMIN_PASSWORD=

# Retell — Speed To Lead (outbound)
RETELL_API_KEY=
RETELL_AGENT_ID=
RETELL_FROM_NUMBER=
RETELL_WEBHOOK_SECRET=

# Retell — Receptionist (inbound, Phase 7)
RETELL_RECEPTIONIST_NUMBER=
RETELL_RECEPTIONIST_AGENT_ID=
RETELL_RECEPTIONIST_LLM_ID=
